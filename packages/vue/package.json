{
  "name": "@ardinsys/financial-charts-vue",
  "version": "1.0.0-rc.2",
  "description": "Official Vue 3 bindings for @ardinsys/financial-charts — a chart component owning lifecycle, data replacement, runtime options, and Teleport-based custom indicator labels.",
  "keywords": [
    "charts",
    "financial",
    "candlestick",
    "trading",
    "canvas",
    "vue"
  ],
  "homepage": "https://docs.ardinsys.eu/financial-charts/integrations/vue.html",
  "type": "module",
  "license": "Apache-2.0",
  "author": "ARDINSYS Zrt.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ardinsys/financial-charts.git",
    "directory": "packages/vue"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && pnpm verify:package",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:package": "tsc -p scripts/consumer-fixtures/tsconfig.json && node -e \"import('./dist/index.js')\""
  },
  "peerDependencies": {
    "@ardinsys/financial-charts": "workspace:^",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@ardinsys/financial-charts": "workspace:*",
    "@types/node": "^24.13.3",
    "jsdom": "^29.1.1",
    "tsdown": "^0.22.9",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue": "^3.5.40"
  }
}

{
  "name": "@ardinsys/financial-charts",
  "version": "1.0.0-rc.2",
  "description": "Canvas-based charting engine for financial time series — candlestick, bar, line, area, and HLC controllers, indicators, drawings, and plugins. Framework agnostic, zero runtime dependencies.",
  "keywords": [
    "charts",
    "charting",
    "financial",
    "candlestick",
    "ohlc",
    "trading",
    "stock",
    "canvas",
    "timeseries"
  ],
  "homepage": "https://docs.ardinsys.eu/financial-charts",
  "type": "module",
  "license": "Apache-2.0",
  "author": "ARDINSYS Zrt.",
  "packageManager": "pnpm@10.24.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ardinsys/financial-charts.git",
    "directory": "packages/core"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "README.md",
    "MIGRATION.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "import": "./dist/extensions.js"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./controllers/area": {
      "types": "./dist/controllers/area.d.ts",
      "import": "./dist/controllers/area.js"
    },
    "./controllers/bar": {
      "types": "./dist/controllers/bar.d.ts",
      "import": "./dist/controllers/bar.js"
    },
    "./controllers/candle": {
      "types": "./dist/controllers/candle.d.ts",
      "import": "./dist/controllers/candle.js"
    },
    "./controllers/hlc-area": {
      "types": "./dist/controllers/hlc-area.d.ts",
      "import": "./dist/controllers/hlc-area.js"
    },
    "./controllers/hollow-candle": {
      "types": "./dist/controllers/hollow-candle.d.ts",
      "import": "./dist/controllers/hollow-candle.js"
    },
    "./controllers/line": {
      "types": "./dist/controllers/line.d.ts",
      "import": "./dist/controllers/line.js"
    },
    "./controllers/stepline": {
      "types": "./dist/controllers/stepline.d.ts",
      "import": "./dist/controllers/stepline.js"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && pnpm verify:package",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:package": "node scripts/verify-package-exports.mjs && tsc -p scripts/consumer-fixtures/tsconfig.json && node scripts/verify-tree-shaking.mjs"
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.9",
    "@types/node": "^24.13.3",
    "bumpp": "^11.1.0",
    "jsdom": "^29.1.1",
    "tsdown": "^0.22.9",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}

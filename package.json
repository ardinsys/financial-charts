{
  "name": "@ardinsys/financial-charts-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @ardinsys/financial-charts-playground dev",
    "playground": "pnpm --filter @ardinsys/financial-charts-playground dev",
    "build": "pnpm --filter @ardinsys/financial-charts build",
    "test": "pnpm --filter @ardinsys/financial-charts test",
    "typecheck": "pnpm --filter @ardinsys/financial-charts typecheck",
    "verify:package": "pnpm --filter @ardinsys/financial-charts verify:package",
    "docs:dev": "pnpm --filter @ardinsys/financial-charts-docs dev",
    "docs:build": "pnpm --filter @ardinsys/financial-charts-docs build",
    "docs:preview": "pnpm --filter @ardinsys/financial-charts-docs preview"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}

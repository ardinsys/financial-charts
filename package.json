{
  "name": "@ardinsys/financial-charts-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @ardinsys/financial-charts-playground dev",
    "playground": "pnpm --filter @ardinsys/financial-charts-playground dev",
    "build": "pnpm -r --filter './packages/**' --if-present run build",
    "test": "pnpm -r --filter './packages/**' --if-present run test",
    "typecheck": "pnpm -r --filter './packages/**' --if-present run typecheck",
    "format": "oxfmt",
    "verify:package": "pnpm --filter @ardinsys/financial-charts verify:package",
    "docs:dev": "pnpm --filter @ardinsys/financial-charts-docs dev",
    "docs:build": "pnpm --filter @ardinsys/financial-charts-docs build",
    "docs:preview": "pnpm --filter @ardinsys/financial-charts-docs preview",
    "showcase": "pnpm build && pnpm --filter @ardinsys/financial-charts-showcase dev",
    "showcase:dev": "pnpm build && pnpm --filter @ardinsys/financial-charts-showcase dev",
    "showcase:build": "pnpm build && pnpm --filter @ardinsys/financial-charts-showcase build",
    "showcase:generate": "pnpm build && pnpm --filter @ardinsys/financial-charts-showcase generate"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0"
  }
}
